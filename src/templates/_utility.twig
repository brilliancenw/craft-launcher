{% import "_includes/forms" as forms %}

<div id="launcher-table-utility">
    <h2>Rocket Launcher Database Status</h2>

    <div class="field">
        <div class="heading">
            <label>User History Table</label>
            <div class="instructions">
                <p>The launcher uses this database table to track user launch history and provide intelligent search suggestions.</p>
            </div>
        </div>
        <div class="input">
            {% if tableStatus.exists %}
                <div class="flex items-center">
                    <span class="status green" data-icon="check"></span>
                    <span>{{ tableStatus.message }}</span>
                </div>

                {% if stats %}
                    <div style="margin-top: 15px;">
                        <h4>Table Statistics</h4>
                        <table class="data">
                            <tbody>
                                <tr>
                                    <th class="light">Total History Records</th>
                                    <td>{{ stats.totalRecords|number_format }}</td>
                                </tr>
                                <tr>
                                    <th class="light">Active Users</th>
                                    <td>{{ stats.totalUsers|number_format }}</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            {% else %}
                <div class="flex items-center" style="margin-bottom: 15px;">
                    <span class="status red" data-icon="alert"></span>
                    <span>{{ tableStatus.message }}</span>
                </div>

                <div style="padding: 15px; background: #fef2f2; border: 1px solid #fecaca; border-radius: 4px; margin-bottom: 15px;">
                    <h4 style="margin-top: 0; color: #dc2626;">Action Required</h4>
                    <p><strong>The user history table is missing.</strong> This means launch history and popular items won't work properly.</p>

                    <p><strong>Choose one of the following options to fix this:</strong></p>
                    <ul>
                        <li><strong>Option 1:</strong> Use the "Create User History Table" button below</li>
                        <li><strong>Option 2:</strong> Reinstall the plugin: <code>php craft plugin/uninstall launcher && php craft plugin/install launcher</code></li>
                        <li><strong>Option 3:</strong> Run the console command: <code>php craft launcher/default/create-table</code></li>
                    </ul>
                </div>

                <button type="button"
                        class="btn submit"
                        id="create-table-btn"
                        onclick="createLauncherTable()">
                    Create User History Table
                </button>
            {% endif %}
        </div>
    </div>

    <hr>

    <div class="field">
        <div class="heading">
            <label>System Information</label>
        </div>
        <div class="input">
            <table class="data">
                <tbody>
                    <tr>
                        <th class="light" style="width: 30%;">Plugin Version</th>
                        <td>{{ pluginVersion }}</td>
                    </tr>
                    <tr>
                        <th class="light">Craft Version</th>
                        <td>{{ craftVersion }}</td>
                    </tr>
                    <tr>
                        <th class="light">History Tracking</th>
                        <td>
                            {% if settings.enableLaunchHistory %}
                                <span class="status green" data-icon="check"></span> Enabled
                            {% else %}
                                <span class="status" data-icon="minus"></span> Disabled in settings
                            {% endif %}
                        </td>
                    </tr>
                    {% if not tableStatus.exists %}
                    <tr>
                        <th class="light">Impact</th>
                        <td style="color: #dc2626;">
                            Search functionality works normally, but user history and popular items are disabled.
                        </td>
                    </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    {% if not tableStatus.exists %}
    <div class="field" style="margin-top: 30px;">
        <div class="heading">
            <label>Advanced Options</label>
        </div>
        <div class="input">
            <p>If the automatic table creation fails, you can try these console commands:</p>
            <div style="background: #f9f9f9; padding: 10px; border-radius: 4px; font-family: monospace;">
                # Check status<br>
                php craft launcher/default/status<br><br>
                # Create table manually<br>
                php craft launcher/default/create-table<br><br>
                # View statistics (after table is created)<br>
                php craft launcher/default/stats
            </div>
        </div>
    </div>
    {% endif %}

    <hr>

    <h2>Search Index Status</h2>

    <div class="field">
        <div class="heading">
            <label>Indexed Sections</label>
            <div class="instructions">
                <p>Shows which sections have entries indexed for search. If entries are missing from search results, try reindexing.</p>
            </div>
        </div>
        <div class="input">
            {% if searchIndexStatus.error is defined %}
                <div class="flex items-center">
                    <span class="status red" data-icon="alert"></span>
                    <span>Error checking search index: {{ searchIndexStatus.error }}</span>
                </div>
            {% else %}
                <table class="data fullwidth">
                    <thead>
                        <tr>
                            <th>Section</th>
                            <th>Total Entries</th>
                            <th>Indexed</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for section in searchIndexStatus.sections %}
                        <tr>
                            <td><strong>{{ section.name }}</strong> <span class="light">({{ section.handle }})</span></td>
                            <td>{{ section.entryCount|number_format }}</td>
                            <td>{{ section.indexedCount|number_format }}</td>
                            <td>
                                {% if section.isFullyIndexed %}
                                    <span class="status green"></span> Indexed
                                {% elseif section.indexedCount == 0 %}
                                    <span class="status red"></span> Not indexed
                                {% else %}
                                    <span class="status orange"></span> Partial
                                {% endif %}
                            </td>
                            <td>
                                <button type="button"
                                        class="btn small reindex-btn"
                                        data-section="{{ section.handle }}"
                                        onclick="reindexSection('{{ section.handle }}', this)">
                                    Reindex
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>

                <div style="margin-top: 15px;">
                    <button type="button" class="btn" id="reindex-all-btn" onclick="reindexAllSections()">
                        Reindex All Sections
                    </button>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="field">
        <div class="heading">
            <label>Searchable Fields</label>
            <div class="instructions">
                <p>Fields configured to be included in the search index. Content in these fields will be searchable via the launcher.</p>
            </div>
        </div>
        <div class="input">
            {% if searchIndexStatus.searchableFields|length %}
                <table class="data">
                    <thead>
                        <tr>
                            <th>Field Name</th>
                            <th>Handle</th>
                            <th>Type</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for field in searchIndexStatus.searchableFields %}
                        <tr>
                            <td>{{ field.name }}</td>
                            <td><code>{{ field.handle }}</code></td>
                            <td>{{ field.type }}</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            {% else %}
                <p class="light">No searchable fields found. Enable "Use this field's values as search keywords" in field settings.</p>
            {% endif %}

            <p style="margin-top: 15px;">
                <strong>Total indexed keywords:</strong> {{ searchIndexStatus.totalIndexedKeywords|number_format }}
            </p>
        </div>
    </div>

    <hr>

    <h2>Troubleshooting</h2>

    <div class="field">
        <div class="heading">
            <label>Generate Diagnostic Report</label>
            <div class="instructions">
                <p>Download a diagnostic report to help troubleshoot issues. This report contains system information, plugin settings, and content counts. <strong>No personal data is included.</strong></p>
            </div>
        </div>
        <div class="input">
            <form id="diagnostic-form" method="post" action="{{ actionUrl('launcher/utility/generate-diagnostic-report') }}">
                {{ csrfInput() }}
                <button type="submit" class="btn" id="download-diagnostic-btn">
                    Download Diagnostic Report
                </button>
            </form>
            <p style="margin-top: 10px; font-size: 0.9em; color: #666;">
                The report includes: plugin version, Craft version, PHP version, database info, content counts, all plugin settings, and installed plugins list.
            </p>
        </div>
    </div>
</div>

<script>
function reindexSection(sectionHandle, btn) {
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Reindexing...';

    fetch('{{ actionUrl('launcher/utility/reindex-section') }}', {
        method: 'POST',
        headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-Token': '{{ craft.app.request.csrfToken }}'
        },
        body: JSON.stringify({ section: sectionHandle })
    })
    .then(response => response.json())
    .then(data => {
        if (data && data.success) {
            Craft.cp.displayNotice(data.message || 'Section reindexed successfully!');
            setTimeout(() => location.reload(), 1000);
        } else {
            Craft.cp.displayError(data?.error || 'Failed to reindex section.');
            btn.disabled = false;
            btn.textContent = originalText;
        }
    })
    .catch(error => {
        console.error('Reindex error:', error);
        Craft.cp.displayError('Error reindexing section: ' + error.message);
        btn.disabled = false;
        btn.textContent = originalText;
    });
}

function reindexAllSections() {
    const btn = document.getElementById('reindex-all-btn');
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Reindexing All...';

    fetch('{{ actionUrl('launcher/utility/reindex-all') }}', {
        method: 'POST',
        headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-Token': '{{ craft.app.request.csrfToken }}'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data && data.success) {
            Craft.cp.displayNotice(data.message || 'All sections reindexed successfully!');
            setTimeout(() => location.reload(), 1500);
        } else {
            Craft.cp.displayError(data?.error || 'Failed to reindex sections.');
            btn.disabled = false;
            btn.textContent = originalText;
        }
    })
    .catch(error => {
        console.error('Reindex error:', error);
        Craft.cp.displayError('Error reindexing: ' + error.message);
        btn.disabled = false;
        btn.textContent = originalText;
    });
}

function createLauncherTable() {
    const btn = document.getElementById('create-table-btn');
    const originalText = btn.textContent;

    btn.disabled = true;
    btn.textContent = 'Creating Table...';

    // Make AJAX request to create the table
    fetch('{{ actionUrl('launcher/utility/create-table') }}', {
        method: 'POST',
        headers: {
            'Accept': 'application/json',
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'X-CSRF-Token': '{{ craft.app.request.csrfToken }}'
        }
    })
    .then(response => {
        if (!response.ok) {
            throw new Error(`HTTP error! status: ${response.status}`);
        }
        return response.json();
    })
    .then(data => {
        if (data && data.success) {
            // Reload the utility to show the updated status
            Craft.cp.displayNotice('User history table created successfully!');
            setTimeout(() => location.reload(), 1000); // Small delay to show notice
        } else {
            Craft.cp.displayError(data?.error || 'Failed to create table. Please try the console command.');
            btn.disabled = false;
            btn.textContent = originalText;
        }
    })
    .catch(error => {
        console.error('Fetch error:', error);
        Craft.cp.displayError('Network error occurred: ' + error.message + '. Please try the console command.');
        btn.disabled = false;
        btn.textContent = originalText;
    });
}
</script>